{
  "name": "@ovellum/site",
  "version": "0.0.0",
  "private": true,
  "description": "Static site builder for Ovellum manual mode: Markdown → HTML.",
  "license": "MIT",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -b --force && node -e \"require('fs').cpSync('src/templates', 'dist/templates', { recursive: true })\"",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ignore-pattern \"src/templates/**\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ovellum/core": "workspace:*",
    "@ovellum/reader": "workspace:*",
    "gray-matter": "^4.0.3",
    "lucide": "^1.16.0",
    "pagefind": "^1.5.2",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4"
  }
}
