{
  "name": "ovellum",
  "version": "0.0.0",
  "description": "Ovellum CLI - documentation tool for TypeScript and JavaScript projects.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ovellum": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -b --force",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "@ovellum/core": "workspace:*",
    "@ovellum/generator": "workspace:*",
    "@ovellum/merger": "workspace:*",
    "@ovellum/parser": "workspace:*",
    "@ovellum/reader": "workspace:*",
    "@ovellum/site": "workspace:*",
    "chokidar": "^5.0.0",
    "citty": "^0.2.2",
    "gray-matter": "^4.0.3"
  }
}
