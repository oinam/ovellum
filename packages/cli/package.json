{
  "name": "ovellum",
  "version": "0.24.0",
  "mcpName": "io.github.oinam/ovellum",
  "description": "Ovellum is an open-source documentation tool for TypeScript and JavaScript. It lets auto-generated API docs and hand-written narrative live together in the same files, without conflict.",
  "keywords": [
    "documentation",
    "docs",
    "typescript",
    "javascript",
    "markdown",
    "mdx",
    "static-site-generator",
    "api-docs",
    "tsdoc",
    "jsdoc",
    "site-generator"
  ],
  "license": "MIT",
  "author": "Brajeshwar Oinam <brajeshwar@oinam.com>",
  "homepage": "https://ovellum.oss.oinam.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oinam/ovellum.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/oinam/ovellum/issues"
  },
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/api.js",
  "module": "./dist/api.js",
  "types": "./dist/api.d.ts",
  "bin": {
    "ovellum": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    }
  },
  "files": [
    "dist/**/*",
    "!dist/.tsbuildinfo",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -b --force && tsup && node ../../scripts/cli-copy-templates.mjs",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm -w build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "c12": "3.3.4",
    "chokidar": "^5.0.0",
    "citty": "^0.2.2",
    "gray-matter": "^4.0.3",
    "lucide": "^1.16.0",
    "pagefind": "^1.5.2",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.2",
    "ts-morph": "^28.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "peerDependencies": {
    "esbuild": ">=0.19.0",
    "sharp": "^0.33.0 || ^0.34.0"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": true
    },
    "sharp": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ovellum/core": "workspace:*",
    "@ovellum/generator": "workspace:*",
    "@ovellum/merger": "workspace:*",
    "@ovellum/parser": "workspace:*",
    "@ovellum/reader": "workspace:*",
    "@ovellum/site": "workspace:*"
  }
}
