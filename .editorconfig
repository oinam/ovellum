root = true

[*]

# Recommendation: Keep these Unchanged
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# change these settings to your own preference
indent_style = space
indent_size = 2

# custom file styles
[*.{md,txt}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
